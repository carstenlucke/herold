APP_NAME=Herold
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/data/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

# Herold Auth
HEROLD_API_KEY=
HEROLD_ADMIN_EMAIL=herold@flitzpeople.com

# OpenAI
OPENAI_API_KEY=

# GitHub
HEROLD_GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Vite Dev Server (Docker)
VITE_DEV_SERVER_URL=http://localhost:5173
